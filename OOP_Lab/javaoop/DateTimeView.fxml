<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="200.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="DateTimeController">
   <children>
      <TextField fx:id="tfDisplay" layoutX="50.0" layoutY="50.0" prefHeight="40.0" prefWidth="300.0" editable="false">
         <font>
            <Font size="14.0" />
         </font>
      </TextField>
      
      <Button layoutX="125.0" layoutY="110.0" mnemonicParsing="false" onAction="#showDateTime" prefHeight="40.0" prefWidth="150.0" text="Show Date Time">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
   </children>
</AnchorPane>